{
  "name": "allegiant-web-wizardd",
  "version": "0.1.0",
  "private": true,
  "description": "Allegiant's turnkey website production engine. Takes a partner's A.R.C. Report and intake form, produces three design directions with launch-ready content, AI/traditional/technical SEO artifacts, schema markup, image specs, and Avada implementation notes.",
  "license": "UNLICENSED",
  "author": "Allegiant Digital Marketing",
  "homepage": "https://wizardd.allegiantdigital.co",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/allegiant-digital-marketing/allegiant-web-wizardd.git"
  },
  "scripts": {
    "start": "cross-env LLM_CACHE_MODE=replay node src/server.js",
    "start:live": "cross-env LLM_CACHE_MODE=fallback node src/server.js",
    "validate:schemas": "node tests/schemas/validate.js",
    "test:parser": "cross-env LLM_CACHE_MODE=replay node tests/parser/test-parser.js",
    "test:parser:live": "cross-env LLM_CACHE_MODE=live node tests/parser/test-parser.js",
    "test:parser:record": "cross-env LLM_CACHE_MODE=record node tests/parser/test-parser.js",
    "parser:dump": "cross-env LLM_CACHE_MODE=replay node tests/parser/dump-parsed.js",
    "parser:dump:record": "cross-env LLM_CACHE_MODE=record node tests/parser/dump-parsed.js",
    "test": "npm run validate:schemas && npm run test:parser",
    "test:live": "npm run validate:schemas && npm run test:parser:live"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "cross-env": "^7.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
